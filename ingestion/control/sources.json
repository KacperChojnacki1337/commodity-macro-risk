{
  "schema_version": "1.0",
  "sources": [
    {
      "source_id": "nbp",
      "enabled": true,
      "description": "National Bank of Poland - daily FX mid rates (USD/PLN, EUR/PLN).",
      "base_url": "https://api.nbp.pl/api/exchangerates/tables/A",
      "auth_type": "none",
      "secret_name": null,
      "http_method": "GET",
      "response_format": "json",
      "frequency": "daily",
      "landing_container": "raw",
      "landing_path_template": "source=nbp/dataset=fx_rates_table_a/ingest_date={ingest_date}",
      "file_name_template": "nbp_table_a_{ingest_date}.json",
      "incremental_strategy": "full_snapshot",
      "date_window_days": 93,
      "notes": "Keyless. Range endpoint limited to ~93 days per request; backfill in windows."
    },
    {
      "source_id": "nbp_history",
      "enabled": false,
      "description": "One-off NBP Table A backfill (2026-04-20..2026-07-17) so the marts have a real time series.",
      "base_url": "https://api.nbp.pl/api/exchangerates/tables/A/2026-04-20/2026-07-17/",
      "auth_type": "none",
      "secret_name": null,
      "http_method": "GET",
      "response_format": "json",
      "frequency": "once",
      "landing_container": "raw",
      "landing_path_template": "source=nbp/dataset=fx_rates_table_a/ingest_date={ingest_date}",
      "file_name_template": "nbp_table_a_backfill_2026-04-20_2026-07-17.json",
      "incremental_strategy": "full_snapshot",
      "date_window_days": 93,
      "notes": "Range endpoint returns one document per business day. Set enabled=false once it has run; kept as a record of the backfill."
    },
    {
      "source_id": "eia_wti_spot",
      "enabled": true,
      "description": "EIA - WTI crude oil spot price, Cushing OK (series RWTC), daily, USD per barrel.",
      "base_url": "https://api.eia.gov/v2/petroleum/pri/spt/data/?frequency=daily&data[0]=value&facets[series][]=RWTC&start=2026-04-01&sort[0][column]=period&sort[0][direction]=asc&length=5000",
      "auth_type": "api_key",
      "secret_name": "eia-api-key",
      "http_method": "GET",
      "response_format": "json",
      "frequency": "daily",
      "landing_container": "raw",
      "landing_path_template": "source=eia/dataset=wti_spot/ingest_date={ingest_date}",
      "file_name_template": "eia_wti_spot_{ingest_date}.json",
      "incremental_strategy": "full_snapshot",
      "date_window_days": null,
      "notes": "First api_key source. The key is NOT here - only secret_name, resolved from Key Vault at runtime by ADF's managed identity and appended as &api_key=."
    },
    {
      "source_id": "eia_brent_spot",
      "enabled": true,
      "description": "EIA - Brent crude oil spot price, Europe (series RBRTE), daily, USD per barrel.",
      "base_url": "https://api.eia.gov/v2/petroleum/pri/spt/data/?frequency=daily&data[0]=value&facets[series][]=RBRTE&start=2026-04-01&sort[0][column]=period&sort[0][direction]=asc&length=5000",
      "auth_type": "api_key",
      "secret_name": "eia-api-key",
      "http_method": "GET",
      "response_format": "json",
      "frequency": "daily",
      "landing_container": "raw",
      "landing_path_template": "source=eia/dataset=brent_spot/ingest_date={ingest_date}",
      "file_name_template": "eia_brent_spot_{ingest_date}.json",
      "incremental_strategy": "full_snapshot",
      "date_window_days": null,
      "notes": "Same EIA endpoint and key as WTI, different series (RBRTE). Both flow into the generic EIA_PETROLEUM_SPOT_RAW bronze table and stg_eia__petroleum_spot."
    },
    {
      "source_id": "openmeteo",
      "enabled": true,
      "description": "Open-Meteo - daily weather for Warsaw (temp max/min, precipitation). Demand-signals domain.",
      "base_url": "https://archive-api.open-meteo.com/v1/archive?latitude=52.23&longitude=21.01&start_date=2026-04-01&end_date=2026-07-20&daily=temperature_2m_max,temperature_2m_min,precipitation_sum&timezone=auto",
      "auth_type": "none",
      "secret_name": null,
      "http_method": "GET",
      "response_format": "json",
      "frequency": "daily",
      "landing_container": "raw",
      "landing_path_template": "source=openmeteo/dataset=warsaw_daily/ingest_date={ingest_date}",
      "file_name_template": "openmeteo_warsaw_daily_{ingest_date}.json",
      "incremental_strategy": "full_snapshot",
      "date_window_days": null,
      "notes": "Keyless. Archive API returns parallel arrays under 'daily' (time[i] matches temperature_2m_max[i]); staging zips them by index. Archive has a ~5-day lag."
    }
  ]
}
