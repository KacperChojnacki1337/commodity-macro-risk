# NOTE: .gitignore only treats "#" as a comment at the START of a line.
# Never put trailing comments after a pattern — they become part of it.

# === Secrets & credentials (NEVER commit) ===
*.env
.env
.env.*
*.pem
*.key
secrets/

# dbt connection profile (may contain Snowflake credentials)...
**/profiles.yml
# ...but keep the credential-free template.
!dbt/profiles.example.yml

# === Terraform ===
.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json

# tfvars may contain secrets; commit *.tfvars.example instead.
*.tfvars
!*.tfvars.example

# === dbt ===
dbt/target/
dbt/dbt_packages/
dbt/logs/
.user.yml

# === Python (helper scripts / dbt) ===
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# === Power BI (large binaries; publish screenshots to docs instead) ===
*.pbix

# === OS / editor noise ===
.DS_Store
Thumbs.db
.vscode/
.idea/
